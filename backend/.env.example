# DECA Configurator API — Environment Configuration
# Copy to .env and fill in values

# PostgreSQL connection
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/deca_crm
DB_SCHEMA=configurator

# Server
PORT=4000
NODE_ENV=production

# CORS — frontend URL
CORS_ORIGIN=https://decacrm.com

# Google Embeddings (optional, for AI parameter matching)
# GOOGLE_EMBEDDINGS_KEY=
# GOOGLE_EMBEDDINGS_MODEL=text-embedding-004
# GOOGLE_EMBEDDINGS_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
